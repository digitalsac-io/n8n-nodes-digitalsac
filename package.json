{
  "name": "n8n-nodes-digitalsac",
  "version": "1.2.2",
  "description": "Izing Pro Digitalsac",
  "keywords": [
    "n8n",
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/digitalsac-io/n8n-nodes-digitalsac",
  "author": {
    "name": "Digitalsac.io",
    "email": "contato@digitalsac.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/digitalsac-io/n8n-nodes-digitalsac.git"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials package.json --write",
    "lint": "eslint nodes credentials package.json --ext .ts,.json",
    "lintfix": "eslint nodes credentials package.json --ext .ts,.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DigitalsacApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Digitalsac/Digitalsac.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^18.0.0",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/eslint-plugin": "~5.45",
    "@typescript-eslint/parser": "~5.45",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^4.0.2",
    "n8n-core": "^1.0.0",
    "n8n-workflow": "^1.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
